# Serial release-candidate profile. A 16 GiB GPU cannot host this beside production.
QWEN_COMPOSE_PROJECT=qwen35-candidate
QWEN_CONTAINER_NAME=qwen35-9b-candidate
QWEN_PUBLISH_ADDRESS=127.0.0.1:18081
# Production is stopped during candidate validation, so ModelPort can exercise
# the candidate through the stable internal provider contract.
QWEN_NETWORK_ALIAS=qwen-runtime
QWEN_RESTART_POLICY=no
QWEN_CACHE_DIR=./cache/candidate
QWEN_CTX_SIZE=131072
QWEN_PARALLEL=1
QWEN_N_PREDICT=32768
QWEN_CACHE_RAM=8192
